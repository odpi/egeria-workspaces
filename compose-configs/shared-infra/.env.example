# ─────────────────────────────────────────────────────────────────────────────
# shared-infra — environment configuration template
# Copy this file to .env and fill in values for your environment.
# .env is gitignored; .env.example is committed and kept up to date.
# ─────────────────────────────────────────────────────────────────────────────

# ── Host / network ────────────────────────────────────────────────────────────
HOST_FQDN=myhost.local

# Stable cluster ID — any fixed string. Do not change after first startup
# or Kafka will refuse to start (data directory mismatch).
KAFKA_CLUSTER_ID=42

# ── Container images ──────────────────────────────────────────────────────────
# Pin to a specific digest for reproducible builds, or use a tag for flexibility.
SHARED_KAFKA_IMAGE=cleanstart/kafka@sha256:3bfad519feac67e6bd1ae2b18b3e4770cdf2fedf53ecff7b38a520a7c5d77564
SHARED_POSTGRES_IMAGE=pgvector/pgvector:pg17

# ── Kafka data directories (host paths) ───────────────────────────────────────
# Absolute path on the host where Kafka persists its data.
HARDENED_KAFKA_DATA_DIR=/path/to/egeria-workspaces-fs/runtime-volumes/shared-infra-hardened-kafka
HARDENED_KAFKA_LOG_DIR=/var/lib/kafka-data/kraft-logs
