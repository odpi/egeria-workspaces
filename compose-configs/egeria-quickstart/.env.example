# ─────────────────────────────────────────────────────────────────────────────
# egeria-quickstart — environment configuration template
# Copy this file to .env and fill in values for your environment.
# .env is gitignored; .env.example is committed and kept up to date.
# ─────────────────────────────────────────────────────────────────────────────

# ── Host / network ────────────────────────────────────────────────────────────
# Fully-qualified hostname of this machine (used by Egeria and Kafka).
HOST_FQDN=myhost.local

# Gateway IP Docker containers use to reach the host.
# Leave unset to use the default "host-gateway" magic hostname.
# HOST_GATEWAY_IP=192.168.1.50

# Kafka bootstrap address reachable from inside containers.
KAFKA_BOOTSTRAP_SERVERS=myhost.local:9194


# ── Auth / JWT (demo mode) ────────────────────────────────────────────────────
# Change this before exposing the stack externally. Any long random string works.
# Example: openssl rand -hex 32
JWT_SECRET=change-me-before-going-public

# Admin account auto-created on first startup in demo mode (DEMO_MODE=true).
# Leave blank to skip auto-bootstrap.
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=


# ── Email / notifications (demo mode) ────────────────────────────────────────
# Resend (https://resend.com) is used for magic-link login emails.
# Leave blank to disable email; login links will appear in the server log instead.
RESEND_API_KEY=
RESEND_FROM=


# ── Obsidian integration ──────────────────────────────────────────────────────
# Set to false to disable the session lock entirely (single-user / freshstart).
# When disabled, the portal tile shows a direct link with no acquire/release flow.
OBSIDIAN_LOCK_ENABLED=true

# Controls which Obsidian the portal tile opens.
#
#   Empty (default) — portal opens the containerized Obsidian at port 3000.
#
#   Vault name      — portal constructs obsidian://open?vault=<name> and
#                     hands it to the browser, opening your local Obsidian app.
#                     Use this when you have Obsidian installed on this machine.
#
#   Full URI        — used as-is (e.g. obsidian://open?vault=coco-workbooks&file=Home)
#
# Examples:
#   OBSIDIAN_VAULT_URL=coco-workbooks          # local Obsidian, coco vault
#   OBSIDIAN_VAULT_URL=                        # containerized Obsidian (default)
OBSIDIAN_VAULT_URL=


# ── Egeria Advisor ────────────────────────────────────────────────────────────
# URL of the Egeria Advisor service if running on a non-default host/port.
# Checked server-side; defaults to http://localhost:8880/. For a public
# deployment (SITE_URL on a real domain), use Advisor's public HTTPS URL here
# instead of localhost — see demo-mode.md § Egeria Advisor integration.
EGERIA_ADVISOR_URL=

# Shared HS256 secret with Egeria Advisor's own ADVISOR_PORTAL_SECRET, used to
# mint the SSO handoff token for the "Ask Advisor" tile. Leave blank to disable
# the tile's SSO handoff (see demo-mode.md § Egeria Advisor integration).
EGERIA_ADVISOR_SSO_SECRET=


# ── MCP access token ─────────────────────────────────────────────────────────
# The MCP_ACCESS_TOKEN is hardcoded in egeria-quickstart.yaml as
# "egeria-secret-mcp-token". To use a custom token, override it here and
# update the matching setting in the Call Dr. Egeria Obsidian plugin.
# MCP_ACCESS_TOKEN=egeria-secret-mcp-token


# ── my-egeria persona ─────────────────────────────────────────────────────────
# Persona used by the my-egeria Textual app (single-user V1).
# All browser sessions share this persona. Change to any Coco Pharmaceuticals
# user (e.g. peterprofile, faithbroker) to explore a different profile.
QUICKSTART_PERSONA_USER=erinoverview
QUICKSTART_PERSONA_PASSWORD=secret


# ── Shared PostgreSQL admin role ──────────────────────────────────────────────
# Used by bin/apply-postgres-init.sh to apply the Egeria DB init migration.
# The defaults below match the egeria_admin role created by the postgres init
# SQL and work out of the box for the local quickstart — leave them unset unless
# you customised the postgres setup. (The script exports PGPASSWORD so psql does
# not prompt.)
# PGUSER=egeria_admin
# PGPASSWORD=admin4egeria
