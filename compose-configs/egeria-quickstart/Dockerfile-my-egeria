FROM python:3.12-slim
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
RUN pip install --no-cache-dir pyegeria --upgrade
EXPOSE 8020
# The pyegeria console-script entry point has a packaging bug (wrong import path).
# Invoke textual serve directly on the known app file instead.
CMD ["sh", "-c", "python -m textual serve --host ${MY_EGERIA_HOST:-0.0.0.0} --port ${MY_PROFILE_PORT:-8020} /usr/local/lib/python3.12/site-packages/my_egeria/my_egeria/DemoCode/My_Profile/my_profile_app.py"]
