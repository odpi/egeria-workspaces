FROM python:3.12-slim
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
# pip install of textual does not install the `textual` console script;
# use textual_serve.server.Server programmatically via serve_my_egeria.py instead.
RUN pip install --no-cache-dir pyegeria --upgrade && \
    pip install --no-cache-dir "textual==6.1.0"
COPY serve_my_egeria.py /usr/local/bin/serve_my_egeria.py
# my_profile.tcss is missing from pyegeria's package_data (fixed upstream);
# inject it manually until a new pyegeria release includes it.
COPY my_profile.tcss /tmp/my_profile.tcss
RUN find /usr/local/lib -name "my_profile_app.py" \
    -exec sh -c 'cp /tmp/my_profile.tcss "$(dirname "$1")/my_profile.tcss"' _ {} \;
EXPOSE 8020
CMD ["python", "/usr/local/bin/serve_my_egeria.py"]
