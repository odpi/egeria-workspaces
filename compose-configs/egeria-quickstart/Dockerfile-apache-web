FROM httpd:2.4-bookworm

# For settng up FastAPI
COPY ./sites-available/fastapi-proxy.conf /usr/local/apache2/conf/extra/fastapi-proxy.conf

# Install Python runtime for optional CGI tooling.
# Use HTTPS apt sources to avoid environments that block outbound HTTP.
RUN sed -i 's|http://deb.debian.org|https://deb.debian.org|g' /etc/apt/sources.list.d/*.sources && \
    apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    python3 \
    python3-pip \
    python3-venv && \
    rm -rf /var/lib/apt/lists/*

# Enable the necessary Apache modules for reverse proxying
# These are often enabled by default, but explicitly enabling ensures it.
# The 'a2enmod' command is not available in the httpd image, so we modify httpd.conf directly.
# This sed command uncomments the LoadModule lines for proxy and proxy_http
RUN sed -i '/^#LoadModule proxy_module modules\/mod_proxy.so/s/^#//' /usr/local/apache2/conf/httpd.conf && \
    sed -i '/^#LoadModule proxy_http_module modules\/mod_proxy_http.so/s/^#//' /usr/local/apache2/conf/httpd.conf && \
    sed -i '/^#LoadModule rewrite_module modules\/mod_rewrite.so/s/^#//' /usr/local/apache2/conf/httpd.conf

# This tells Apache to load your fastapi-proxy.conf
RUN echo "Include conf/extra/fastapi-proxy.conf" >> /usr/local/apache2/conf/httpd.conf


# Set working directory
WORKDIR /usr/local/apache2

# Create a Python virtual environment for CGI scripts
RUN python3 -m venv /usr/local/apache2/venv

# Install pyegeria and other required Python packages in the virtual environment
RUN /usr/local/apache2/venv/bin/pip install --upgrade pip && \
    /usr/local/apache2/venv/bin/pip install pyegeria


# Make sure the CGI scripts directory exists
RUN mkdir -p /usr/local/apache2/htdocs/cgi-bin

# Create a wrapper script to activate the virtual environment for CGI scripts
RUN echo '#!/bin/bash\nsource /usr/local/apache2/venv/bin/activate\nexec "$@"' > /usr/local/apache2/venv_wrapper.sh && \
    chmod +x /usr/local/apache2/venv_wrapper.sh

# Set permissions for CGI scripts
RUN chmod -R 755 /usr/local/apache2/htdocs/cgi-bin
